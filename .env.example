# Copy to .env (which is gitignored) and fill in your keys.
# run.py sources this file and exports the keys into the process env
# so the hermes CLI (and its auxiliary judge calls) pick them up.

# Required: Anthropic API key — used for both the agent and the bare judge
# when judges.yaml entries set provider: anthropic.
ANTHROPIC_API_KEY=

# Optional: Faces platform key — only required if you add a judge with
# `face: <alias>@<base-model>` in judges.yaml. Faces routes through an
# OpenAI-compatible endpoint, so the runner writes
#   auxiliary.goal_judge.base_url = https://api.faces.sh/v1
#   auxiliary.goal_judge.api_key  = $FACES_API_KEY
# into the per-heat hermes config when a face is configured.
FACES_API_KEY=

# Optional: alternate Faces base URL (leave blank for the default).
FACES_BASE_URL=
